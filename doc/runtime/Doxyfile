PROJECT_NAME           = "PLibESPV1 Runtime Library"
PROJECT_BRIEF          = "ESP runtime support library for configuration, status, networking, messaging and utilities."
OUTPUT_DIRECTORY       = doc/runtime
CREATE_SUBDIRS         = NO

INPUT                  = README.md include doc/pageBuilder.md doc/CWebSocket.md doc/runtime/mainpage.md
USE_MDFILE_AS_MAINPAGE = doc/runtime/mainpage.md
RECURSIVE              = YES
EXCLUDE                = doc/runtime/html doc/runtime/xml doc/runtime/latex doc/runtime/markdown doc/runtime/pdf doc/runtime/tools
FILE_PATTERNS          = *.h *.hpp *.cpp *.c *.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
SEARCHENGINE           = YES

GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = NO

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

PREDEFINED             = NATIVE_RUNTIME \
                         ICACHE_FLASH_ATTR= \
                         F(x)=x \
                         __FlashStringHelper=char
