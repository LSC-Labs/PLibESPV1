        <argsstring>(const char *pszKey, const TValue value)</argsstring>
        <name>set</name>
        <qualifiedname>CNamedValueTable::set</qualifiedname>
        <param>
          <type>const char *</type>
          <declname>pszKey</declname>
        </param>
        <param>
          <type>const TValue</type>
          <declname>value</declname>
        </param>
        <briefdescription>
<para>Sets or inserts a named value. </para>
        </briefdescription>
        <detaileddescription>
<para>Base table behavior:<itemizedlist>
<listitem><para>Duplicate keys are allowed.</para>
</listitem><listitem><para>Duplicate values are allowed.</para>
</listitem><listitem><para>A new entry is appended on every successful <ref refid="class_c_named_value_table_1a6ded152edec08c14135b6e25b8221d27" kindref="member">set()</ref>.</para>
</listitem></itemizedlist>
</para>
<para>Derived table behavior:<itemizedlist>
<listitem><para><ref refid="class_c_unique_name_multi_value_table" kindref="compound">CUniqueNameMultiValueTable</ref> updates an existing key instead of adding another entry with the same key.</para>
</listitem><listitem><para><ref refid="class_c_multi_name_unique_value_table" kindref="compound">CMultiNameUniqueValueTable</ref> rejects a new entry when the value already exists.</para>
</listitem></itemizedlist>
</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>pszKey</parametername>
</parameternamelist>
<parameterdescription>
<para>Key for the entry. May be nullptr, but nullptr keys cannot be found by key lookup. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>value</parametername>
</parameternamelist>
<parameterdescription>
<para>Value to store. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Address of the inserted or updated entry, or nullptr when a uniqueness rule rejects the operation. </para>
</simplesect>
</para>
        </detaileddescription>
